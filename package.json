{
  "name": "ima-stickermanage-monorepo",
  "version": "1.0.0",
  "private": true,
  "description": "FIFA World Cup 2026 sticker collection monorepo",
  "packageManager": "pnpm@11.8.0+sha512.c1f5e7c4cb241c8f174b743851d82f42b802324afc8b0f116b96adb15aa06664948dde36960a3ba1079ba5b4b29dd0140135b94b5b5f5263592249d68e555f26",
  "type": "module",
  "scripts": {
    "build": "turbo run build",
    "build:desktop": "pnpm --filter @ima-stickermanage/desktop build",
    "dev": "turbo run dev --filter=@ima-stickermanage/client --filter=@ima-stickermanage/server",
    "dev:desktop": "turbo run dev --filter=@ima-stickermanage/client --filter=@ima-stickermanage/desktop",
    "lint": "turbo run lint",
    "lint:fix": "turbo run lint:fix",
    "format": "turbo run format",
    "format:check": "turbo run format:check",
    "start": "pnpm --filter @ima-stickermanage/server start"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "globals": "^17.6.0",
    "prettier": "catalog:default",
    "turbo": "^2.9.18",
    "typescript": "catalog:default",
    "typescript-eslint": "^8.61.1"
  }
}
