{
  "name": "@ima-stickermanage/server",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "esbuild src/index.ts --bundle --platform=node --format=esm --packages=external --outfile=dist/server.js",
    "start": "node dist/server.js",
    "dev": "node scripts/dev.mjs",
    "lint": "eslint . && prettier . --check --ignore-path ../../.prettierignore",
    "lint:fix": "eslint . --fix && prettier . --write --ignore-path ../../.prettierignore",
    "format": "prettier . --write --ignore-path ../../.prettierignore",
    "format:check": "prettier . --check --ignore-path ../../.prettierignore"
  },
  "dependencies": {
    "@ima-stickermanage/contracts": "workspace:*",
    "better-sqlite3": "^11.8.1",
    "express": "^4.21.2"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/express": "^5.0.0",
    "@types/node": "^24.0.0",
    "esbuild": "^0.24.2",
    "typescript": "^5.7.3"
  }
}
