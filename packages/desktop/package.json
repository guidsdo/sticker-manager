{
  "name": "@ima-stickermanage/desktop",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "main": "dist/main.js",
  "author": {
    "name": "guidsdo",
    "email": "guidsdo@users.noreply.github.com",
    "url": "https://github.com/guidsdo/sticker-manager"
  },
  "description": "Desktop app version to have an offline sticker manager",
  "scripts": {
    "build": "pnpm --filter @ima-stickermanage/client build && node esbuild.config.mjs",
    "rebuild:native": "node scripts/rebuild-native.mjs",
    "dev": "pnpm run build && pnpm run rebuild:native && electron .",
    "lint": "eslint . && prettier . --check --ignore-path ../../.prettierignore",
    "lint:fix": "eslint . --fix && prettier . --write --ignore-path ../../.prettierignore",
    "format": "prettier . --write --ignore-path ../../.prettierignore",
    "format:check": "prettier . --check --ignore-path ../../.prettierignore",
    "package": "pnpm run build && pnpm run rebuild:native && electron-builder --publish never"
  },
  "dependencies": {
    "@ima-stickermanage/contracts": "workspace:*",
    "@ima-stickermanage/messagebus": "workspace:*",
    "@ima-stickermanage/server": "workspace:*",
    "better-sqlite3": "^12.11.1"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.4",
    "@types/node": "catalog:default",
    "electron": "^42.4.1",
    "electron-builder": "^26.15.3",
    "electron-builder-squirrel-windows": "26.15.3",
    "esbuild": "catalog:default",
    "typescript": "catalog:default"
  },
  "build": {
    "appId": "io.guidsdo.stickermanager",
    "productName": "Sticker Manager 2026",
    "executableName": "sticker-manager-2026",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**",
      "../client/dist/public/**",
      "package.json"
    ],
    "mac": {
      "target": [
        "dmg"
      ]
    },
    "win": {
      "target": [
        "nsis"
      ]
    },
    "linux": {
      "target": [
        "AppImage"
      ]
    }
  }
}
