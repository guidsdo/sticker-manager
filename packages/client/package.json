{
  "name": "@ima-stickermanage/client",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "node esbuild.config.mjs",
    "dev": "node esbuild.config.mjs --watch",
    "lint": "eslint . && prettier . --check --ignore-path ../../.prettierignore",
    "lint:fix": "eslint . --fix && prettier . --write --ignore-path ../../.prettierignore",
    "format": "prettier . --write --ignore-path ../../.prettierignore",
    "format:check": "prettier . --check --ignore-path ../../.prettierignore"
  },
  "dependencies": {
    "@ima-stickermanage/contracts": "workspace:*",
    "mobx": "catalog:default",
    "mobx-react-lite": "catalog:default",
    "react": "catalog:default",
    "react-dom": "catalog:default",
    "styled-components": "catalog:default"
  },
  "devDependencies": {
    "@types/react": "catalog:default",
    "@types/react-dom": "catalog:default",
    "esbuild": "catalog:default",
    "typescript": "catalog:default"
  }
}
