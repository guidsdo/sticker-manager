    "styled-components": "^6.1.14"
  },
  "devDependencies": {
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "esbuild": "^0.24.2",
    "typescript": "^5.7.3"
  }
}
