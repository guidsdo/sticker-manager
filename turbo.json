{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", "packages/*/dist/**"]
    },
    "package": {
      "dependsOn": ["build"],
      "outputs": ["dist/**", "packages/*/release/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "lint": {
      "dependsOn": ["^lint"]
    },
    "lint:fix": {
      "cache": false
    },
    "format": {
      "cache": false
    },
    "format:check": {
      "dependsOn": ["^format:check"]
    },
    "start": {
      "cache": false,
      "persistent": true
    }
  }
}
